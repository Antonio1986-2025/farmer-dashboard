{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "aptPackages": ["libnss3", "libnspr4", "libatk1.0-0", "libatk-bridge2.0-0", "libcups2", "libdrm2", "libdbus-1-3", "libxcb1", "libxkbcommon0", "libx11-6", "libxcomposite1", "libxdamage1", "libxext6", "libxfixes3", "libxrandr2", "libgbm1", "libpango-1.0-0", "libcairo2", "libasound2", "libatspi2.0-0"]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "uvicorn servidor:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/api/dados",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": [
    {
      "name": "web",
      "sourceRepository": "https://github.com/SEU_USUARIO/farmer-dashboard",
      "domains": []
    },
    {
      "name": "coleta-diaria",
      "cronSchedule": "0 10 * * 1-5",
      "command": "curl -X POST https://SEU_PROJETO.railway.app/api/coletar",
      "sourceRepository": "https://github.com/SEU_USUARIO/farmer-dashboard"
    }
  ]
}
